---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">IN THE <strong>FIFTY</strong></span>
      <p class="footer-tagline">A thoughtful home for the Studio50 launch.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#studio50">Studio50</a></li>
        <li><a href="#support">Support</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>&copy; {currentYear} IN THE FIFTY. All rights reserved.</p>
    <p class="footer-disclaimer">American made first. Built to champion businesses across all fifty states.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: #9aabcc;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
  }

  /* Brand */
  .footer-logo {
    display: block;
    font-size: 1.3rem;
    font-weight: 800;
    font-family: var(--font-display);
    color: var(--color-white);
    margin-bottom: 0.4rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .footer-logo strong {
    color: var(--color-red);
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: #7080a0;
  }

  /* Nav */
  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-nav a {
    font-size: 0.85rem;
    font-weight: 500;
    color: #9aabcc;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: var(--color-white);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1rem 1.25rem;
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .footer-disclaimer {
    color: #5a6888;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-nav ul {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
