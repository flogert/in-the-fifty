---
interface Product {
  id: number;
  name: string;
  description: string;
  category: string;
  madeIn: string;
  badge?: string;
}

const products: Product[] = [
  {
    id: 1,
    name: 'Classic Canvas Tote',
    description: 'Heavy-duty canvas tote, hand-stitched in the American South. Built to last a lifetime.',
    category: 'Bags & Accessories',
    madeIn: 'Tennessee',
    badge: 'Best Seller',
  },
  {
    id: 2,
    name: 'Steel Water Bottle',
    description: 'Double-walled stainless steel bottle, manufactured in Ohio. Keeps cold 24h, hot 12h.',
    category: 'Drinkware',
    madeIn: 'Ohio',
  },
  {
    id: 3,
    name: 'Beeswax Candle Set',
    description: 'Hand-poured pure beeswax candles sourced from local apiaries in the Pacific Northwest.',
    category: 'Home & Living',
    madeIn: 'Oregon',
    badge: 'New',
  },
  {
    id: 4,
    name: 'Heritage Work Gloves',
    description: 'Full-grain leather gloves cut and sewn in Texas. Worn by pros, loved by everyone.',
    category: 'Outdoors & Work',
    madeIn: 'Texas',
  },
  {
    id: 5,
    name: 'Wildflower Honey',
    description: 'Raw, unfiltered wildflower honey from small-batch hives across the Midwest prairies.',
    category: 'Food & Pantry',
    madeIn: 'Kansas',
    badge: 'Fan Favorite',
  },
  {
    id: 6,
    name: 'Ceramic Mug',
    description: 'Wheel-thrown and kiln-fired stoneware mug. Every piece is one-of-a-kind.',
    category: 'Home & Living',
    madeIn: 'Vermont',
  },
];
---

<section id="products" class="products-section">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">🇺🇸 100% American Made</p>
      <h2 class="section-title">Featured Products</h2>
      <p class="section-subtitle">
        Handpicked goods made by American workers, shipped from American soil.
      </p>
    </header>

    <div class="products-grid">
      {products.map((product) => (
        <article class="product-card">
          <div class="product-image-placeholder" aria-hidden="true">
            <span class="product-icon">🛒</span>
          </div>
          {product.badge && (
            <span class="product-badge">{product.badge}</span>
          )}
          <div class="product-body">
            <p class="product-category">{product.category}</p>
            <h3 class="product-name">{product.name}</h3>
            <p class="product-description">{product.description}</p>
            <p class="product-made-in">
              <span class="flag">🇺🇸</span> Made in {product.madeIn}
            </p>
            <a href="#shop" class="product-btn">View Product</a>
          </div>
        </article>
      ))}
    </div>

    <div class="products-footer">
      <a href="#shop" class="btn-primary-lg">Browse All Products</a>
    </div>
  </div>
</section>

<style>
  .products-section {
    padding: 5rem 1.25rem;
    background: var(--color-light-gray);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-red);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    color: var(--color-dark);
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    font-size: 1rem;
    color: #555;
    max-width: 520px;
    margin: 0 auto;
  }

  /* Grid */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* Card */
  .product-card {
    background: var(--color-white);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
  }

  /* Placeholder image area — replace with real <img> when assets are ready */
  .product-image-placeholder {
    background: linear-gradient(135deg, #e8eaf0, #d0d4e8);
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-icon {
    font-size: 3rem;
    opacity: 0.4;
  }

  .product-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-red);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 50px;
  }

  .product-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-category {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-blue);
    margin-bottom: 0.4rem;
  }

  .product-name {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-dark);
    margin-bottom: 0.5rem;
  }

  .product-description {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 0.75rem;
  }

  .product-made-in {
    font-size: 0.8rem;
    font-weight: 600;
    color: #777;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .product-btn {
    display: block;
    text-align: center;
    background: var(--color-dark);
    color: var(--color-white);
    padding: 0.65rem 1rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: background 0.2s;
  }

  .product-btn:hover {
    background: var(--color-blue);
  }

  /* Footer CTA */
  .products-footer {
    text-align: center;
    margin-top: 3rem;
  }

  .btn-primary-lg {
    display: inline-block;
    background: var(--color-red);
    color: var(--color-white);
    padding: 1rem 2.5rem;
    border-radius: 6px;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary-lg:hover {
    background: #8b1a27;
    transform: translateY(-2px);
  }
</style>
